# ==========================================
# Root .gitignore for Code Snippets Project
# ==========================================

# --- System / OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDEs and Text Editors ---
# IntelliJ
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse / STS / NetBeans
.classpath
.project
.settings/
.factorypath
.apt_generated/
.springBeans/
.sts4-cache/
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/
*.code-workspace

# Miscellaneous Editors
.c9/
*.launch
*.sublime-workspace
*.swp
*~

# --- Local Workspace / Agent Tooling ---
.agents/
.codex/
.playwright-cli/
.playwright-mcp/
trash/
/tmp/

# --- Environment & Credentials ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- Java / Maven (api) ---
**/target/
!**/src/main/**/target/
!**/src/test/**/target/
.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar

# --- Node / Angular (web) ---
**/node_modules/
**/dist/
**/out-tsc/
**/bazel-out/
**/.angular/cache/
.sass-cache/
/web/connect.lock
/web/coverage/
/web/libpeerconnection.log
/web/testem.log
/web/typings/
**/__screenshots__/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Docker ---
.docker-build/
